pipeline {
    agent any

    tools {
        nodejs 'node20'
    }

    environment {
        DOCKER_IMAGE = "portfolio-app"
        CONTAINER_NAME = "portfolio-prod"
        PORT = "3003"
        VITE_SUPABASE_URL = credentials('SUPABASE_URL')
        VITE_SUPABASE_ANON_KEY = credentials('SUPABASE_ANON_KEY')
    }

    // Handled manually, so no triggers section here.

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Deploy to Production') {
            steps {
                echo "Deploying to Production Environment (Port ${PORT})..."
                script {
                    sh "docker stop ${CONTAINER_NAME} || true"
                    sh "docker rm ${CONTAINER_NAME} || true"
                    sh "docker build --build-arg VITE_SUPABASE_URL=${VITE_SUPABASE_URL} --build-arg VITE_SUPABASE_ANON_KEY=${VITE_SUPABASE_ANON_KEY} -t ${DOCKER_IMAGE}:prod ."
                    sh "docker run -d -p ${PORT}:80 --name ${CONTAINER_NAME} ${DOCKER_IMAGE}:prod"
                }
            }
        }
    }
}
